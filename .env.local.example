# ─────────────────────────────────────────────────────────────
# OpenNEtrikkan Simulator — Environment Variables
#
# 1. Copy this file to .env.local
# 2. Fill in your Supabase project values
# 3. Never commit .env.local to git
# ─────────────────────────────────────────────────────────────

# From: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — server-side only, never expose to the browser
# From: Supabase Dashboard → Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
